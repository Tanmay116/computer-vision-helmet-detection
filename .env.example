# Application
APP_NAME="Helmet Detection API"
APP_VERSION="1.0.0"
DEBUG=false

# Model
MODEL_PATH=best.onnx
MODEL_CONFIDENCE_THRESHOLD=0.25
MODEL_IOU_THRESHOLD=0.45
MODEL_DEVICE=cpu           # Options: cpu | cuda:0 | cuda:1

# Rate Limiting
RATE_LIMIT_PREDICT=60/minute

# Google Cloud Logging
# Leave empty to fall back to structured JSON stdout.
GCP_PROJECT_ID=
LOG_NAME=helmet-detection-api

# Inference Retry
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_MIN_SECONDS=0.5
RETRY_WAIT_MAX_SECONDS=4.0

# File Upload
MAX_UPLOAD_SIZE_BYTES=10485760   # 10 MB
